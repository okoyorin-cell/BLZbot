# Copie en ".env" à la racine du dépôt (à côté de package.json).

# --- Obligatoire ---
BOT_TOKEN=
# Doit être l’ID du serveur où CE bot est membre (même valeur que modération/.env si un seul serveur principal).
GUILD_ID=
# Optionnel : serveur où déployer /panel (déban). Vide ou absent = même valeur que GUILD_ID.
PANEL_GUILD_ID=

# --- Mode TEST (guilde 1493276404643532810 par défaut) ---
# BLZ_TEST_MODE=1 ou BLZ_BOT_PROFILE=test → GUILD_ID (et PANEL_GUILD_ID sauf ci‑dessous) sont forcés pour tester les slash / la logique sur le serveur de test.
# BLZ_TEST_MODE=
# Autre guilde de test (optionnel) :
# TEST_GUILD_ID=
# Serveur « principal » (prod) : si défini, les slash niveau + modération sont aussi enregistrés sur cette guilde (en plus de GUILD_ID), même hors mode test.
# En mode test, si absent, l’ancienne valeur de GUILD_ID peut y être copiée pour garder le déploiement double test + prod.
# Exemple prod : BLZ_MAIN_GUILD_ID=1097110036192448656
# BLZ_MAIN_GUILD_ID=
# Garder PANEL_GUILD_ID du .env en mode test (ne pas le remplacer par la guilde test) :
# BLZ_TEST_KEEP_PANEL_GUILD=1

# Désactive au démarrage les captchas anti-AFK vocaux (1 / true / yes / on). Réactivables avec /anti-afk sans redémarrer.
# VOICE_AFK_DISABLED=

# --- Salons spécifiques au serveur de test (économie séparée : blzbot.test.sqlite) ---
# Tutoriel / bienvenue test (défaut 1493276591529263185 si vide) :
# TEST_TUTORIAL_CHANNEL_ID=
# Annonces niveau / rang / streak sur le test (sinon pas d’annonce sur ces salons) :
# TEST_LEVEL_UP_CHANNEL=
# TEST_RANK_UP_CHANNEL=
# TEST_STREAK_CHANNEL=

# --- Modération : logs sur le serveur de test (défaut 1493282572925669498 si vide) ---
# TEST_ALL_LOG_CHANNEL_ID=
# TEST_MOD_LOG_CHANNEL_ID=
# TEST_RAID_LOG_CHANNEL_ID=

# --- Salons vocaux privés (niveau) : rejoindre le lobby → création d’un vocal dans la catégorie ---
# Lobby d’accueil (défaut 1388968408711823411). Sur un autre serveur, mets l’ID du vocal « Crée ton vocale » OU un nom exact ci‑dessous (le bot résout aussi par nom si l’ID ne correspond pas).
PRIVATE_ROOM_LOBBY_CHANNEL_ID=
# Optionnel : nom exact du salon lobby vocal (si plusieurs serveurs / ID différent).
PRIVATE_ROOM_LOBBY_NAME=
# Optionnel : par défaut le code utilise la catégorie vocaux privés du serveur BLZ (1388968406664871986). Surcharge ici si besoin.
PRIVATE_ROOM_CATEGORY_ID=
# Optionnel : salon texte pour l’embed « ton salon vocal ». Sinon : premier salon texte de la même catégorie, ou salon système du serveur.
PRIVATE_ROOM_PANEL_CHANNEL_ID=
# Mets 0 pour désactiver même si la catégorie est définie.
PRIVATE_ROOM_ENABLED=

# --- Salons / rôles (IDs Discord) ---
GUILD_CHANNEL=
GUILD_CATEGORY=
COMPTAGE=
TUTORIAL_CHANNEL=
QUEST_CHANNEL=
LEVEL_UP_CHANNEL=
RANK_UP_CHANNEL=
STREAK_CHANNEL=
HACKER_CHANNEL=
REGLEMENT_ROLE=

# --- Logs : INFO (défaut hors orchestrateur), WARN/ERROR moins bavard ---
# Sous "npm start", mode compact → WARN automatique sauf si tu forces LOG_LEVEL ici.
LOG_LEVEL=

# --- Orchestrateur : délai entre forks (ms), défaut ~400. 0 = tout d’un coup. ---
BLZ_FORK_DELAY_MS=
# Services forkés au démarrage (défaut: moderation,niveau,ia). "all" = tout — plusieurs gateways avec le même token = risqué.
BLZ_FORK_SERVICES=
# Logs des process enfants : défaut WARN (ignore LOG_LEVEL=DEBUG du .env). Mets INFO pour plus de détail.
BLZ_CHILD_LOG_LEVEL=

# Niveau : 1 = ne JAMAIS déployer les slash au démarrage (/panel-voc absent tant que tu ne lances pas deploy:commands ailleurs). Laisse vide ou 0 sur l’hébergeur.
SKIP_SLASH_DEPLOY_ON_START=
# (Obsolète pour le deploy slash — ne force plus SKIP.) Autres usages éventuels : laisser vide.
BLZ_FAST_START=
# Délai de base (ms) avant sync boosters / salons guildes / comptage au ready (défaut 1500).
BLZ_DEFER_STARTUP_MS=
# Après [READY], attendre ce délai (ms) avant d’enregistrer les slash (modération + niveau). Vide sous orchestrateur = 5000. 0 = immédiat.
BLZ_DEFER_SLASH_DEPLOY_MS=

# --- Module IA (processus ia/index.js) ---
# Obligatoire pour démarrer l’IA : les réponses passent par Gemini en premier (ordre des modèles dans ia/config.js).
GEMINI_API_KEY=
# Optionnel : modèles Groq du registre si tu veux les utiliser depuis le panneau / sélecteur.
GROQ_API_KEY=
# Optionnel : surcharger le salon (embed) pour les alertes « deux réponses IA identiques d’affilée » (défaut : serveur 1493276404643532810, salon 1493623997986766919).
# IA_DUPLICATE_LOG_GUILD_ID=
# IA_DUPLICATE_LOG_CHANNEL_ID=
# 1 (défaut si vide) = répondre au @bot dans tout salon texte du serveur. 0 = seulement PUBLIC_IA_CHANNEL_ID (+ IDs ci‑dessous).
IA_MENTION_ANY_CHANNEL=
# IDs supplémentaires (séparés par virgule) où une mention du bot déclenche l’IA, comme le salon « public ».
IA_EXTRA_PUBLIC_CHANNEL_IDS=
# Cooldown par utilisateur (ms) pour les mentions hors salon public dédié (défaut 5000). 0 = désactivé.
IA_GUILD_MENTION_COOLDOWN_MS=
# Rafraîchissement du message Discord pendant le stream Groq (ms, défaut 300 ; min 200, max 3000).
# IA_STREAM_EDIT_INTERVAL_MS=
# 1/true = appel Groq supplémentaire pour résumer l’historique sur salon « public » (plus lent). Désactivé par défaut.
# IA_SUMMARY_PUBLIC_MENTION=
# Optionnel : surcharger les IDs codés dans ia/config.js (panneau IA, salon public, hard mode).
# IA_PANEL_CHANNEL_ID=
# PUBLIC_IA_CHANNEL_ID=
# HARD_MODE_CHANNEL_ID=

# --- Optionnel ---
GITHUB_TOKEN_ISSUE=
GITHUB_ISSUES_URL=

.env.example