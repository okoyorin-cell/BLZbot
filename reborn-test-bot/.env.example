# Fichier à copier :  cp .env.example .env   (ou duplique ce fichier en .env)
# Le bot lit UNIQUEMENT : reborn-test-bot/.env  (pas la racine du repo)

# --- Bot test ---
# Portail Discord → ton application de TEST → Bot → Reset Token / copier le token
# Ne mets jamais ce fichier .env dans Git (déjà dans .gitignore)
REBORN_TEST_BOT_TOKEN=colle_ton_token_ici_sans_guillemets

# Même page → Application ID (identifiant de l’application, pas le token)
REBORN_TEST_BOT_CLIENT_ID=colle_l_id_application_ici

# --- Serveur test (guild) ---
# Discord (mode développeur activé) → clic droit sur le serveur → Copier l’identifiant du serveur
# Utilisé par npm run deploy pour enregistrer les slash commands tout de suite sur ce serveur
REBORN_TEST_GUILD_ID=colle_l_id_du_serveur_test_ici

# Optionnel : tes IDs Discord pour /wallet set, /purge si tu n’es pas le owner de l’app Team
# Plusieurs IDs : 123456789,987654321
REBORN_TEST_OWNER_IDS=
